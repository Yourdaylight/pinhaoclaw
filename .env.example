# PinHaoClaw 配置文件
# 复制为 .env 后修改，启动时自动加载
# 环境变量优先级：系统环境变量 > .env 文件 > 默认值

# ── 基础 ──
PINHAOCLAW_HOME=~/.pinhaoclaw
PINHAOCLAW_FRONTEND_DIR=pinhaoclaw-frontend/dist/build/h5
PINHAOCLAW_PUBLIC_ORIGIN=http://localhost:9000

# ── 管理后台 ──
PINHAOCLAW_ADMIN_PASSWORD=
PINHAOCLAW_ADMIN_PATH=

# ── 默认节点（可选，也可在管理后台添加）──
PINHAOCLAW_REMOTE_HOST=
PINHAOCLAW_REMOTE_SSH_PORT=22
PINHAOCLAW_REMOTE_USER=root
PINHAOCLAW_REMOTE_KEY_PATH=
PINHAOCLAW_REMOTE_PASSWORD=
PINHAOCLAW_REMOTE_HOME=/opt/pinhaoclaw
PINHAOCLAW_REMOTE_REGION=华南

# ── 认证模式 ──
# invite = 邀请码模式 | sidecar = 统一认证（通过 casdoor-auth-sidecar）| auto = 自动检测
PINHAOCLAW_AUTH_MODE=auto

# ── 统一认证 Sidecar ──
# casdoor-auth-sidecar 的内部地址（后端调用 verify 用），如 http://localhost:9098
# 填写后自动启用 sidecar 模式
PINHAOCLAW_AUTH_SIDECAR_URL=

# ── 安全 ──
# SSH 密码加密密钥（64 字符 hex，可选）
# 生成方法: openssl rand -hex 32
PINHAOCLAW_ENCRYPT_KEY=
